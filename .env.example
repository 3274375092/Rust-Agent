# DeepSeek API key. Required unless OPENAI_API_KEY is set.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Fallback API key read by the app when DEEPSEEK_API_KEY is not set.
# OPENAI_API_KEY=sk-your-openai-compatible-api-key

# OpenAI-compatible DeepSeek base URL.
BASE_URL=https://api.deepseek.com

# Chat model used by the agent.
MODEL=deepseek-v4-pro
