# Generic OpenAI-compatible API key. Prefer this for new providers.
API_KEY=sk-your-api-key

# OpenAI-compatible chat completions base URL.
# Examples:
#   DeepSeek:    https://api.deepseek.com
#   OpenAI:      https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
BASE_URL=https://api.deepseek.com

# Chat model used by the agent.
# Examples:
#   deepseek-v4-pro
#   gpt-4.1
#   deepseek/deepseek-chat-v3.1
#   qwen2.5-coder:7b
MODEL=deepseek-v4-pro

# Backward-compatible key names. The app reads these if API_KEY is not set.
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# OPENAI_API_KEY=sk-your-openai-api-key

# Backward-compatible base URL names. The app reads these if BASE_URL is not set.
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENAI_BASE_URL=https://api.openai.com/v1
